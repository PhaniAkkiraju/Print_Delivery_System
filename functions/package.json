{
  "name": "printit-functions",
  "description": "Firebase Cloud Functions for PrintIt — server-side order delivery completion",
  "version": "1.0.0",
  "engines": {
    "node": "18"
  },
  "main": "index.js",
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.9.0"
  },
  "scripts": {
    "serve":  "firebase emulators:start --only functions",
    "shell":  "firebase functions:shell",
    "start":  "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs":   "firebase functions:log"
  },
  "private": true
}
